# Backend Widyaprada - Contoh Environment Variables
# Copy ke .env dan sesuaikan nilai

# Database: postgres | sqlite
DB_TYPE=sqlite

# Server
HTTP_PORT=8080
ENVIRONMENT=development

# PostgreSQL (wajib jika DB_TYPE=postgres)
PGSQL_HOST=localhost
PGSQL_PORT=5432
PGSQL_USERNAME=postgres
PGSQL_PASSWORD=
PGSQL_DBNAME=widyaprada

# Pool koneksi DB
DB_LOG_MODE=true
DB_MAX_IDLE_CONNS=5
DB_MAX_OPEN_CONNS=10
DB_CONN_MAX_LIFETIME=10

# SQLite (wajib jika DB_TYPE=sqlite)
SQLITE_DB_PATH=./data/backend.db

# Migrations (PostgreSQL only). Set ../migrations jika run dari backend/
MIGRATIONS_PATH=migrations

# Redis (optional)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MAX_IDLE=10
REDIS_DB=0

# Sentry (optional)
IS_ENABLE_SENTRY=false
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=1.0.0

# Swagger
SWAGGER_HOST=localhost:8080
SWAGGER_BASE_PATH=

# JWT
JWT_SECRET=widyaprada-secret-change-in-production
JWT_EXPIRY_HOUR=1

# Lupa Password
FRONTEND_URL=http://localhost:3000
RESET_TOKEN_EXPIRY_HOUR=1
